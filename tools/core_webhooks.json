{
  "webhooks": [
    {
      "id": "wh_user_signup_trigger",
      "name": "On New User Signup",
      "description": "Triggers the AI agent when a new user registers on the website.",
      "url_path": "/v1/webhooks/user-signup",
      "method": "POST",
      "enabled": true,
      "target_agent_id": "agent_customer_onboarding_4",
      "security": {
        "auth_type": "hmac_sha256",
        "secret_env_var": "STRIPE_WEBHOOK_SECRET"
      },
      "payload_mapping": {
        "user_email": "body.data.object.email",
        "user_name": "body.data.object.name",
        "plan_type": "body.data.object.plan"
      },
      "response_type": "async"
    },
    {
      "id": "wh_slack_responder",
      "name": "Slack Channel Listener",
      "description": "Routes mentions in Slack directly to the AI support agent.",
      "url_path": "/v1/webhooks/slack-mention",
      "method": "POST",
      "enabled": false,
      "target_agent_id": "agent_slack_bot_main",
      "security": {
        "auth_type": "bearer_token",
        "secret_env_var": "SLACK_VERIFICATION_TOKEN"
      },
      "payload_mapping": {
        "prompt": "body.event.text",
        "channel_id": "body.event.channel"
      },
      "response_type": "sync"
    }
  ]
}
