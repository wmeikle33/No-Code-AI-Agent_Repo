{
  "policy_name": "OAuth Token Storage Policy",
  "version": "1.0",
  "description": "Defines how OAuth access and refresh tokens should be handled in the system.",

  "storage": {
    "access_tokens": "encrypted_secret_store",
    "refresh_tokens": "encrypted_secret_store",
    "local_storage_allowed": false,
    "plaintext_storage_allowed": false
  },

  "security_controls": {
    "encryption_required": true,
    "environment_variables_allowed_for_demo": true,
    "production_secret_manager_required": true,
    "least_privilege_required": true
  },

  "token_lifecycle": {
    "access_token_expiration_handling": "refresh_before_expiration",
    "refresh_token_rotation": "enabled_when_supported",
    "revocation_supported": true
  },

  "logging": {
    "log_token_values": false,
    "log_token_metadata_only": true,
    "redact_secrets_in_errors": true
  },

  "authorized_components": [
    "oauth_flow_handler",
    "credential_vault",
    "tool_executor"
  ],

  "prohibited_practices": [
    "committing tokens to source control",
    "printing tokens in logs",
    "sharing tokens between unrelated agents",
    "using broad scopes when narrow scopes are available"
  ]
