# ============================================================
# No-Code AI Agent Framework - Environment Variables Example
# ============================================================
# Copy this file to .env for local development.
# Never commit a real .env file to version control.

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------

APP_NAME=no-code-ai-agent-framework
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ------------------------------------------------------------
# Runtime Settings
# ------------------------------------------------------------

LOG_LEVEL=INFO
DEFAULT_TIMEZONE=UTC
MAX_WORKFLOW_STEPS=25
ENABLE_HUMAN_REVIEW=true

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

DATABASE_URL=postgresql://username:password@localhost:5432/agent_platform
DATABASE_POOL_SIZE=10
DATABASE_SSL_MODE=disable

# ------------------------------------------------------------
# Redis / Cache / Queue
# ------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0
QUEUE_BACKEND=redis
CACHE_TTL_SECONDS=3600

# ------------------------------------------------------------
# LLM Providers
# ------------------------------------------------------------

OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=replace_with_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

GOOGLE_API_KEY=replace_with_google_api_key
GOOGLE_MODEL=gemini-1.5-pro

# ------------------------------------------------------------
# OAuth Client Credentials
# ------------------------------------------------------------

GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

MICROSOFT_CLIENT_ID=replace_with_microsoft_client_id
MICROSOFT_CLIENT_SECRET=replace_with_microsoft_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

GITHUB_CLIENT_ID=replace_with_github_client_id
GITHUB_CLIENT_SECRET=replace_with_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

SLACK_CLIENT_ID=replace_with_slack_client_id
SLACK_CLIENT_SECRET=replace_with_slack_client_secret
SLACK_REDIRECT_URI=http://localhost:8000/auth/slack/callback

# ------------------------------------------------------------
# Token / Session Security
# ------------------------------------------------------------

TOKEN_ENCRYPTION_KEY=replace_with_32_byte_base64_key
SESSION_SECRET_KEY=replace_with_secure_random_session_secret
JWT_SECRET_KEY=replace_with_secure_random_jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ------------------------------------------------------------
# Storage
# ------------------------------------------------------------

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/storage

AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=replace_with_bucket_name

# ------------------------------------------------------------
# Monitoring / Observability
# ------------------------------------------------------------

ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=replace_with_sentry_dsn

# ------------------------------------------------------------
# Safety / Governance
# ------------------------------------------------------------

ENABLE_AUDIT_LOGGING=true
ENABLE_PII_REDACTION=true
REQUIRE_APPROVAL_FOR_EXTERNAL_ACTIONS=true
