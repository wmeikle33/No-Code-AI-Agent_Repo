# Docker Environment Template
# Copy this file to .env before running Docker

# ==========================================
# Application Settings
# ==========================================

APP_NAME=No-Code-AI-Agent-Repo
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ==========================================
# OpenAI
# ==========================================

OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# Google / Gemma
# ==========================================

GOOGLE_API_KEY=your_google_api_key_here

# ==========================================
# Anthropic
# ==========================================

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==========================================
# Search Providers
# ==========================================

TAVILY_API_KEY=your_tavily_api_key_here
SERPAPI_API_KEY=your_serpapi_api_key_here

# ==========================================
# Database
# ==========================================

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=agents_db
DATABASE_USER=agent_user
DATABASE_PASSWORD=change_me

# ==========================================
# Vector Database
# ==========================================

VECTOR_DB_PROVIDER=chroma

CHROMA_HOST=chroma
CHROMA_PORT=8000

# Alternative Providers
PINECONE_API_KEY=your_pinecone_api_key_here
WEAVIATE_URL=
QDRANT_URL=

# ==========================================
# Email
# ==========================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@example.com

# ==========================================
# Slack
# ==========================================

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ==========================================
# Microsoft
# ==========================================

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ==========================================
# Google Workspace
# ==========================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=

# ==========================================
# HubSpot
# ==========================================

HUBSPOT_ACCESS_TOKEN=

# ==========================================
# Salesforce
# ==========================================

SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=

# ==========================================
# Jira
# ==========================================

JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ==========================================
# ServiceNow
# ==========================================

SERVICENOW_INSTANCE=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# ==========================================
# Security
# ==========================================

JWT_SECRET=replace_with_secure_secret
ENCRYPTION_KEY=replace_with_secure_key

# ==========================================
# Feature Flags
# ==========================================

ENABLE_RESEARCH_AGENT=true
ENABLE_CONTENT_AGENT=true
ENABLE_EMPLOYEE_SUPPORT_AGENT=true
ENABLE_CUSTOMER_SUPPORT_AGENT=true
ENABLE_KPI_AGENT=true

# ==========================================
# Model Defaults
# ==========================================

DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL=gpt-5-mini

CONTENT_AGENT_MODEL=gemma-4
RESEARCH_AGENT_MODEL=gpt-5
DOCUMENT_QA_MODEL=gpt-5
EMPLOYEE_SUPPORT_MODEL=gemma-4
MEETING_NOTES_MODEL=gemma-4
LEAD_QUALIFICATION_MODEL=gpt-5-mini
COORDINATOR_MODEL=gpt-5
