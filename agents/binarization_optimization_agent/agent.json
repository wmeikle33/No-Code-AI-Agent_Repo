{
  "agent_id": "binarization_optimization_agent",
  "name": "Greenscale Binarization Optimization Agent",
  "version": "1.0.0",
  "description": "Evaluates, compares, and optimizes image binarization and segmentation methods for root structure extraction.",

  "agent_type": "computer_vision",

  "domain": "root_phenotyping",

  "responsibilities": [
    "binarization_evaluation",
    "threshold_optimization",
    "segmentation_comparison",
    "mask_quality_analysis",
    "ground_truth_mask_comparison",
    "parameter_tuning",
    "performance_reporting"
  ],

  "supported_tasks": [
    "compare_segmentation_methods",
    "evaluate_masks",
    "check_ground_truth_masks",
    "optimize_thresholds",
    "rank_binarization_algorithms",
    "generate_segmentation_reports",
    "recommend_best_method"
  ],

  "input_types": [
    "root_images",
    "ground_truth_masks",
    "generated_masks",
    "segmentation_metrics",
    "algorithm_parameters",
    "model_goals",
    "image_description"
  ],

  "output_types": [
    "ranked_methods",
    "segmentation_report",
    "optimized_parameters",
    "evaluation_metrics",
    "recommended_method",
    "image_mask"
  ],

  "supported_methods": [
    "otsu_thresholding",
    "adaptive_thresholding",
    "triangle_thresholding",
    "frangi_filter",
    "morphological_processing",
    "canny_edge_detection",
    "watershed_segmentation",
    "custom_pipeline"
  ],

  "evaluation_metrics": [
    "iou",
    "dice_score",
    "precision",
    "recall",
    "f1_score",
    "pixel_accuracy"
  ],

  "optimization_targets": [
    "maximize_iou",
    "maximize_dice_score",
    "maximize_recall",
    "minimize_false_negatives"
  ],

  "allowed_tools": [
    "opencv_processor",
    "mask_evaluator",
    "ground_truth_mask_checker",
    "segmentation_visualizer",
    "parameter_search",
    "metrics_calculator",
    "report_generator"
  ],

  "quality_controls": {
    "require_ground_truth": true,
    "validate_mask_dimensions": true,
    "validate_binary_outputs": true,
    "reject_corrupted_images": true
  },

  "configuration": {
    "top_methods_to_report": 5,
    "save_comparison_figures": true,
    "save_metric_tables": true,
    "generate_recommendations": true
  },

  "permissions_file": "../../code_modules/auth/permissions/agent_permissions/binarization_optimization_agent.json",

  "prompt_file": "system_prompt.md",

  "logging": {
    "log_algorithm_runs": true,
    "log_metric_results": true,
    "log_recommendations": true
  },

  "monitoring": {
    "track_best_iou": true,
    "track_best_dice_score": true,
    "track_method_rankings": true
  },

  "status": "active"
}
