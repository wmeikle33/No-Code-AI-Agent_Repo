{
  "metadata": {
    "name": "meeting_notes_agent",
    "version": "1.2.0",
    "description": "Scans meeting notes and summarizes the content."
  },
  "llm_config": {
    "provider": "anthropic",
    "model": "claude-3-5-sonnet",
    "temperature": 0.2,
    "max_turns": 5
  },
  "behavior": {
    "system_prompt": "You are an automated support assistant. Be polite. Summarize the user issue into three bullet points. Do not make up facts."
  },
   "triggers": [
    {
      "type": "manual"
    }],
  "tools": [
    {
      "name": "post_to_slack",
      "type": "webhook",
      "url": "https://slack.com",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": { "type": "string", "default": "#support-alerts" },
          "text": { "type": "string" }
        },
        "required": ["text"]
      }
    }
  ],
  "memory": {
    "type": "buffer",
    "window_size": 10
  }
}
