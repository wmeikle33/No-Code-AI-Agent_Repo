{
  "id": "content-generator-agent",
  "name": "Content Generator Agent",
  "category": "content-creation",

  "model": {
    "tier": "mid",
    "recommended": "gpt-5"
  },

  "system_prompt": "./system_prompt.md",

  "capabilities": [
    "generate_content",
    "rewrite_content",
    "summarize_content",
    "adjust_tone",
    "seo_optimization"
  ],

  "supported_content_types": [
    "blog_post",
    "newsletter",
    "social_post",
    "article",
    "email",
    "documentation"
  ],

  "tools": [
    "knowledge_search",
    "web_search"
  ],

  "templates": [
    "blog_post",
    "newsletter",
    "social_post"
    "news_article"
    "presentation"
  ],

  "output_formats": [
    "markdown",
    "html",
    "plain_text"
    "pdf"
  ]
}
