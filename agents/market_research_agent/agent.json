{
  "metadata": {
    "name": "market_research_agent",
    "version": "1.2.0",
    "description": "Reads user requests and conducts market research."
  },
  "llm_config": {
    "provider": "anthropic",
    "model": "claude-3-5-sonnet",
    "temperature": 0.2,
    "max_turns": 5
  },
  "behavior": {
    "system_prompt": "You are an automated support assistant. Be polite. Summarize the user issue into three bullet points. Do not make up facts."
  },
  "triggers": [
    {
      "type": "manual"
    },
    {
      "type": "workflow_dispatch",
      "source": "marketing_campaign"
    }
  ]
  },
   "tools": [
    {
      "name": "crm_lookup",
      "required": true
    },
    {
      "name": "company_enrichment",
      "required": true
    },
    {
      "name": "lead_scoring",
      "required": true
    },
    {
      "name": "crm_update",
      "required": true
    }
  ]
  "memory": {
    "type": "buffer",
    "window_size": 10
  }
}

