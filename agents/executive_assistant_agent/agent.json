{
  "id": "executive-assistant-agent",
  "name": "Executice Assitant Agent",
  "version": "1.0.0",
  "description": "Provides employees with answers to HR, IT, payroll, benefits, onboarding, and company policy questions.",
  "category": "executive-assistant",
  "owner": "HR Operations",
  "model": {
    "tier": "mid",
    "recommended": "gpt-5",
    "fallback": "gpt-5-mini"
  },
  "system_prompt": "./system_prompt.md",
  "knowledge_sources": [
    "hr-policies",
    "benefits-documents",
    "it-helpdesk-kb",
    "employee-handbook",
    "onboarding-guides"
  ],
  "behavior": {
    "system_prompt": "You are an automated support assistant. Be polite. Summarize the user issue into three bullet points. Do not make up facts."
  },
  "trigger": {
    "type": "webhook",
    "path": "/v1/hooks/incoming-email"
  },
  "tools": [
    {
      "name": "post_to_slack",
      "type": "webhook",
      "url": "https://slack.com",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": { "type": "string", "default": "#support-alerts" },
          "text": { "type": "string" }
        },
        "required": ["text"]
      }
    }
  ],
  "memory": {
    "type": "buffer",
    "window_size": 10
  }
}
