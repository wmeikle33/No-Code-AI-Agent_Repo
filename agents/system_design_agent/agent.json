{
  "id": "system-design-agent",
  "name": "System Design Agent",
  "version": "1.0.0",
  "description": "Provide system design ideas and recommendations.",
  "category": "productivity",
  "status": "active",

  "model": {
    "tier": "mid",
    "recommended": "gpt-5-mini",
    "fallback": "gemma-4",
    "upgrade_model": "gpt-5",
    "upgrade_when": [
      "multiple speakers or topics must be separated",
      "sensitive business, legal, HR, or financial topics are discussed"
    ]
  },

  "system_prompt": "./system_prompt.md",

  "triggers": [
    {
      "type": "manual",
      "description": "User uploads or pastes meeting notes or transcript"
    },
    {
      "type": "file_uploaded",
      "source": "meeting_transcript"
    },
  ],

  "capabilities": [
    "meeting_summarization",
    "decision_extraction",
    "action_item_extraction",
    "owner_detection",
    "deadline_detection",
    "follow_up_email_drafting",
    "topic_grouping",
    "meeting_record_generation"
  ],

  "tools": [
    {
      "name": "data_reader",
      "required": true,
      "description": "Read and interpret raw data"
    },

  ],

  "knowledge_sources": [
    "raw data"
  ],

  "input_schema": {
    "required": [
      "meeting_content"
    ],
    "optional": [
      "meeting_title",
      "meeting_date",
      "attendees",
      "transcript_file",
      "project_name",
      "desired_output_format"
    ]
  },

  "output_formats": [
    "markdown",
    "plain_text",
    "json"
  ],

  "response_structure": {
    "include_overview": true,
    "include_key_topics": true,
    "include_decisions": true,
    "include_action_items": true,
    "include_owners": true,
    "include_due_dates": true,
    "include_open_questions": true,
    "include_follow_up_draft": true
  },

  "routing": {
    "handoff_conditions": [
      {
        "condition": "requires_executive_briefing",
        "route_to": "executive-assistant-agent"
      },
      {
        "condition": "requires_research_follow_up",
        "route_to": "research-assistant-agent"
      },
      {
        "condition": "requires_customer_support_ticket",
        "route_to": "customer-support-agent"
      },
      {
        "condition": "requires_sales_follow_up",
        "route_to": "lead-qualification-agent"
      }
    ]
  },

  "guardrails": {
    "do_not": [
      "invent_decisions",
      "invent_action_items",
      "assign_owners_when_not_stated",
      "invent_due_dates",
      "send_follow_up_emails_without_approval",
      "share_confidential_meeting_content_with_unauthorized_users"
    ],
    "must_do": [
      "mark missing owners as unassigned",
      "mark missing dates as no_due_date_provided",
      "separate discussion points from decisions",
      "preserve important names, dates, and commitments"
    ],
    "requires_human_review": [
      "external_follow_up_email",
      "legal_or_financial_commitment",
      "hr_or_personnel_discussion",
      "board_or_investor_meeting_summary"
    ]
  },

  "permissions": {
    "allowed_tools": [
      "transcript_parser",
      "speaker_identifier",
      "task_creation",
      "email_draft",
      "calendar_lookup"
    ],
    "restricted_tools": [
      "email_send_without_review",
      "calendar_delete",
      "contract_approval",
      "payroll_access",
      "database_write_without_approval"
    ],
    "allowed_data": [
      "meeting_transcripts",
      "calendar_metadata",
      "attendee_list",
      "project_notes",
      "task_lists"
    ],
    "restricted_data": [
      "private_employee_records",
      "legal_privileged_documents",
      "payroll_records",
      "personal_credentials"
    ]
  },

  "templates": [
    "meeting_summary",
    "action_items",
    "decision_log",
    "follow_up_email",
    "executive_meeting_brief",
    "presentation"
  ],

  "success_metrics": [
    "summary_accuracy",
    "action_item_capture_rate",
    "decision_capture_rate",
    "owner_detection_accuracy",
    "user_satisfaction"
  ],

  "tags": [
    "meeting-notes",
    "summarization",
    "action-items",
    "decisions",
    "productivity"
  ]
}
