{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAgentKnowledgeBase",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::agent-knowledge-bucket",
        "arn:aws:s3:::agent-knowledge-bucket/*"
      ]
    },
    {
      "Sid": "ReadSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": [
        "arn:aws:secretsmanager:*:*:secret:agent/*"
      ]
    }
  ]
}
